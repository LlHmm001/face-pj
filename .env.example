# ============================================
# 人脸识别检索系统 - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置

# ============================================
# 应用配置
# ============================================
# 应用名称（用于容器命名）
APP_NAME=face-recognition

# 应用监听端口（容器内部端口）
APP_PORT=8765

# 应用绑定地址
APP_HOST=0.0.0.0

# ============================================
# 数据库配置
# ============================================
# SQLite 数据库路径
# 格式: sqlite:////path/to/database.db
DATABASE_URL=sqlite:////data/face_recognition.db

# ============================================
# 文件存储配置
# ============================================
# 照片存储目录（容器内部路径）
PHOTOS_DIR=/app/photos

# ============================================
# Uvicorn 服务器配置
# ============================================
# 工作进程数（建议设置为 CPU 核心数）
UVICORN_WORKERS=4

# 日志级别: debug, info, warning, error
UVICORN_LOG_LEVEL=info

# ============================================
# Nginx 配置（可选）
# ============================================
# Nginx HTTP 端口
NGINX_PORT=80

# Nginx HTTPS 端口（启用 SSL 时使用）
NGINX_SSL_PORT=443

# ============================================
# Redis 配置（可选）
# ============================================
# Redis 端口
REDIS_PORT=6379

# Redis 密码（留空则不启用认证）
# REDIS_PASSWORD=your_redis_password_here

# Redis 数据库编号
REDIS_DB=0

# ============================================
# 日志配置
# ============================================
# 日志级别: debug, info, warning, error
LOG_LEVEL=info

# ============================================
# 人脸识别模型配置（可选）
# ============================================
# 模型文件目录（容器内部路径）
# MODEL_DIR=/app/models

# ============================================
# 安全配置（可选）
# ============================================
# API 请求超时时间（秒）
# REQUEST_TIMEOUT=30

# 最大上传文件大小（MB）
# MAX_UPLOAD_SIZE=50
